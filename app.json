{
  "name": "ULTRA GURU",
  "version": "2.0.0",
  "description": "ULTRA GURU Premium WhatsApp Bot | Powered by GuruTech",
  "logo": "https://files.catbox.moe/5evber.jpg",
  "keywords": ["ultra-guru", "whatsapp-bot", "gurutech"],
  "success_url": "/",
  "stack": "heroku-22",
  "env": {
    "SESSION_ID": {
      "description": "Your bot SESSION_ID",
      "required": true,
      "value": ""
    },
    "MODE": {
      "description": "Worktype: public or private",
      "required": true,
      "value": "public"
    },
    "PREFIX": {
      "description": "Command prefix",
      "required": false,
      "value": "."
    }
  },
  "addons": [
    {
      "plan": "heroku-postgresql:essential-0",
      "as": "DATABASE"
    }
  ],
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" }
  ],
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  }
}
